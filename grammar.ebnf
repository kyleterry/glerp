(* glerp scheme grammar *)

program     = { expression } ;

expression  = literal
            | symbol
            | list
            | vector
            | quoted
            | quasiquoted
            | unquoted
            | splice
            | syntax_short
            | quasisyntax_short
            | unsyntax_short
            | unsyntax_splice_short
            | interp_string
            | comment ;

(* literals *)

literal     = number | string | boolean ;
number      = [ "-" ] , digit , { digit } , [ "." , digit , { digit } ] ;
string      = '"' , { char } , '"' ;
boolean     = "#t" | "#f" ;

(* symbols *)

symbol      = symbol_char , { symbol_char } ;
symbol_char = letter | digit | "!" | "?" | "-" | "_" | "+"
            | "*" | "/" | "<" | ">" | "=" | "." | ":" | "@"
            | "~" | "^" | "&" | "%" ;

(* lists and vectors *)

list        = ( "(" | "[" ) , { expression } , ( ")" | "]" ) ;
vector      = "#(" , { expression } , ")" ;

(* quoting *)

quoted      = "'" , expression
            | "(", "quote" , expression , ")" ;

quasiquoted = "`" , expression
            | "(" , "quasiquote" , expression , ")" ;

unquoted    = "," , expression
            | "(" , "unquote" , expression , ")" ;

splice      = ",@" , expression
            | "(" , "unquote-splicing" , expression , ")" ;

(* syntax shorthands *)

syntax_short         = "#'" , expression ;
quasisyntax_short    = "#`" , expression ;
unsyntax_short       = "#," , expression ;
unsyntax_splice_short = "#,@" , expression ;

(* string interpolation *)

interp_string = "$\"" , { interp_segment } , '"' ;
interp_segment = char_no_brace | "{" , expression , "}" ;

(* comments *)

comment     = ";" , { char } ;

(* special forms *)

define      = "(" , "define" , symbol , expression , ")"
            | "(" , "define" , "(" , symbol , params , ")" , body , ")" ;

lambda      = "(" , "lambda" , "(" , params , ")" , body , ")" ;

params      = { symbol } , [ "." , symbol ] ;
body        = expression , { expression } ;

set_bang    = "(" , "set!" , symbol , expression , ")" ;

if_form     = "(" , "if" , expression , expression , [ expression ] , ")" ;

cond        = "(" , "cond" , { cond_clause } , ")" ;
cond_clause = "(" , expression , body , ")"
            | "(" , "else" , body , ")" ;

case_form   = "(" , "case" , expression , { case_clause } , ")" ;
case_clause = "(" , "(" , { literal } , ")" , body , ")"
            | "(" , "else" , body , ")" ;

let         = "(" , "let"  , "(" , { binding } , ")" , body , ")" ;
let_star    = "(" , "let*" , "(" , { binding } , ")" , body , ")" ;
binding     = "(" , symbol , expression , ")" ;

begin       = "(" , "begin" , { expression } , ")" ;

and_form    = "(" , "and" , { expression } , ")" ;
or_form     = "(" , "or"  , { expression } , ")" ;

do_form     = "(" , "do"
                , "(" , { do_binding } , ")"
                , "(" , expression , { expression } , ")"
                , { expression }
              , ")" ;
do_binding  = "(" , symbol , expression , expression , ")" ;

define_values = "(" , "define-values" , "(" , { symbol } , ")" , expression , ")" ;

(* macros — syntax-rules *)

define_syntax = "(" , "define-syntax" , symbol , ( syntax_rules | transformer ) , ")" ;

syntax_rules  = "(" , "syntax-rules" , "(" , { symbol } , ")"
                  , { "(" , pattern , template , ")" }
                , ")" ;

pattern       = expression ;
template      = expression ;

(* macros — syntax-case *)

transformer   = "(" , "lambda" , "(" , symbol , ")" , body , ")" ;

syntax_case   = "(" , "syntax-case" , expression , "(" , { symbol } , ")"
                  , { syntax_clause }
                , ")" ;
syntax_clause = "[" , pattern , body , "]"
              | "[" , pattern , fender , body , "]" ;
fender        = expression ;

syntax_form   = "(" , "syntax" , template , ")"
              | "#'" , template ;

quasisyntax_form = "(" , "quasisyntax" , qs_template , ")"
                 | "#`" , qs_template ;
qs_template      = qs_atom | qs_list ;
qs_atom          = expression ;
qs_list          = "(" , { qs_element } , ")" ;
qs_element       = unsyntax_form | unsyntax_splice_form | qs_template ;

unsyntax_form    = "(" , "unsyntax" , expression , ")"
                 | "#," , expression ;
unsyntax_splice_form = "(" , "unsyntax-splicing" , expression , ")"
                     | "#,@" , expression ;

with_syntax   = "(" , "with-syntax" , "(" , { ws_binding } , ")" , body , ")" ;
ws_binding    = "[" , pattern , expression , "]" ;

(* libraries *)

import_form = "(" , "import" , { import_spec } , ")" ;
import_spec = lib_path
            | "(" , "only" , lib_path , symbol , { symbol } , ")" ;
lib_path    = ":" , symbol , "/" , symbol , { "/" , symbol }
            | "./" , symbol , { "/" , symbol } ;

export_form = "(" , "export" , ( "#t" | symbol , { symbol } ) , ")" ;

(* procedure call *)

call        = "(" , expression , { expression } , ")" ;

(* terminals *)

letter        = "a" | ... | "z" | "A" | ... | "Z" ;
digit         = "0" | ... | "9" ;
char          = ? any character ? ;
char_no_brace = ? any character except { and } ? ;
